# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env

# ── Django ──────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=*

# ── Database: PostgreSQL ────────────────────────────
# Comment out DB_HOST to fall back to SQLite for local dev without PostgreSQL.
#
# Docker Compose (auto-configured):
#   DB_HOST=db
#
# Local PostgreSQL (install postgresql, create user + database manually):
#   DB_HOST=localhost
#   DB_PORT=5432
#   DB_NAME=vampire
#   DB_USER=vampire
#   DB_PASSWORD=change-this-password
#
# Then run:
#   createdb vampire
#   python manage.py migrate
#   python manage.py createsuperuser
DB_HOST=db
DB_PORT=5432
DB_NAME=vampire
DB_USER=vampire
DB_PASSWORD=change-this-password
